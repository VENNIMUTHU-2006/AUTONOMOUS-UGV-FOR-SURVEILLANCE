<?xml version="1.0"?>

<robot name="team12_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- ================= MATERIALS ================= -->

<material name="grey">
  <color rgba="0.6 0.6 0.6 1"/>
</material>

<material name="black">
  <color rgba="0.1 0.1 0.1 1"/>
</material>

<material name="blue">
  <color rgba="0 0.2 0.8 1"/>
</material>


<!-- ================= BASE LINK ================= -->

<link name="base_link"/>


<!-- ================= CHASSIS ================= -->

<link name="chassis_link">

  <inertial>
    <mass value="18.0"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="1.2" iyy="1.2" izz="1.2"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>

  <visual>
    <geometry>
      <box size="0.46 0.30 0.15"/>
    </geometry>
    <material name="grey"/>
  </visual>

  <collision>
    <geometry>
      <box size="0.46 0.30 0.15"/>
    </geometry>
  </collision>

</link>


<joint name="base_joint" type="fixed">
  <parent link="base_link"/>
  <child link="chassis_link"/>
  <origin xyz="0 0 0.1"/>
</joint>


<!-- ================= WHEEL MACRO ================= -->

<xacro:macro name="wheel" params="name x y">

<link name="${name}_link">

  <inertial>
    <mass value="1.5"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.01" iyy="0.02" izz="0.01"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>

  <visual>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.10" length="0.05"/>
    </geometry>
    <material name="black"/>
  </visual>

  <collision>
    <origin rpy="1.5708 0 0"/>
    <geometry>
      <cylinder radius="0.10" length="0.05"/>
    </geometry>
  </collision>

</link>


<joint name="${name}_joint" type="continuous">
  <parent link="chassis_link"/>
  <child link="${name}_link"/>
  <origin xyz="${x} ${y} -0.05"/>
  <axis xyz="0 1 0"/>
</joint>


<!-- Wheel friction -->

<gazebo reference="${name}_link">
  <mu1>8</mu1>
  <mu2>8</mu2>
</gazebo>

</xacro:macro>


<!-- ================= WHEELS ================= -->

<xacro:wheel name="front_left_wheel"  x="0.18"  y="0.15"/>
<xacro:wheel name="front_right_wheel" x="0.18"  y="-0.15"/>

<xacro:wheel name="rear_left_wheel"   x="-0.18" y="0.15"/>
<xacro:wheel name="rear_right_wheel"  x="-0.18" y="-0.15"/>



<!-- ================= LIDAR ================= -->

<link name="lidar_link">

  <inertial>
    <mass value="0.4"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.001" iyy="0.001" izz="0.001"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>

  <visual>
    <geometry>
      <cylinder radius="0.05" length="0.05"/>
    </geometry>
    <material name="blue"/>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.05" length="0.05"/>
    </geometry>
  </collision>

</link>


<joint name="lidar_joint" type="fixed">
  <parent link="chassis_link"/>
  <child link="lidar_link"/>
  <origin xyz="0 0 0.20"/>
</joint>



<!-- ================= DIFF DRIVE ================= -->

<gazebo>

<plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">

  <update_rate>50</update_rate>

  <!-- LEFT SIDE WHEELS -->
  <left_joint>front_left_wheel_joint</left_joint>
  <left_joint>rear_left_wheel_joint</left_joint>

  <!-- RIGHT SIDE WHEELS -->
  <right_joint>front_right_wheel_joint</right_joint>
  <right_joint>rear_right_wheel_joint</right_joint>

  <wheel_separation>0.30</wheel_separation>
  <wheel_diameter>0.20</wheel_diameter>

  <command_topic>cmd_vel</command_topic>
  <odometry_topic>odom</odometry_topic>

  <publish_odom>true</publish_odom>
  <publish_odom_tf>true</publish_odom_tf>

  <robot_base_frame>base_link</robot_base_frame>

</plugin>

</gazebo>



<!-- ================= LIDAR SENSOR ================= -->

<gazebo reference="lidar_link">

<sensor type="ray" name="lidar_sensor">

<update_rate>10</update_rate>

<ray>

<scan>
<horizontal>
<samples>720</samples>
<resolution>1</resolution>
<min_angle>-3.14</min_angle>
<max_angle>3.14</max_angle>
</horizontal>
</scan>

<range>
<min>0.12</min>
<max>10.0</max>
</range>

</ray>

<plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
<topicName>/scan</topicName>
<frameName>lidar_link</frameName>
<output_type>sensor_msgs/LaserScan</output_type>
</plugin>

</sensor>

</gazebo>


</robot>
